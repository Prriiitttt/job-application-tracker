# JobTrackr — frontend environment variables
#
# Only VITE_-prefixed variables are exposed to the browser bundle.
# Never put server secrets here.

# Supabase project URL — Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (publishable) key — Dashboard → Project Settings → API → anon public
# Safe to ship to the browser; RLS gates all data access.
VITE_SUPABASE_ANON_KEY=

# Giphy API key — https://developers.giphy.com (used client-side by GifPicker)
# Optional; the GIF picker is hidden when this key is missing.
VITE_GIPHY_API_KEY=
